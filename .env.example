# =============================================================================
# BBS CRM — Environment Variables
# Kopyala: cp .env.example .env  →  .env dosyasını düzenle
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL
# Format: postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public
# -----------------------------------------------------------------------------
DATABASE_URL="postgresql://bbs_user:SIFRE@DB_IP:5432/bbs_crm?schema=public"

# Shadow DB — SADECE yerel geliştirme için (prisma migrate dev)
# Production'da gerekli değil
# SHADOW_DATABASE_URL="postgresql://bbs_user:SIFRE@DB_IP:5432/bbs_crm_shadow?schema=public"

# -----------------------------------------------------------------------------
# NextAuth / Auth.js
# AUTH_SECRET üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# AUTH_URL = uygulamanın dışarıdan erişilen tam URL'i
# -----------------------------------------------------------------------------
AUTH_SECRET="BURAYA-EN-AZ-32-KARAKTER-GUCLU-SECRET"
AUTH_URL="https://crm.firmaismi.com"
NEXTAUTH_URL="https://crm.firmaismi.com"
NEXTAUTH_SECRET="AUTH_SECRET_ILE_AYNI_DEGER"

# -----------------------------------------------------------------------------
# Uygulama
# -----------------------------------------------------------------------------
NODE_ENV="production"
APP_URL="https://crm.firmaismi.com"
APP_TIMEZONE="Europe/Istanbul"
APP_LOCALE="tr-TR"

# -----------------------------------------------------------------------------
# Dosya depolama (local filesystem)
# UPLOAD_DIR: web root dışında, mutlak yol
# -----------------------------------------------------------------------------
STORAGE_DRIVER="local"
UPLOAD_DIR="/var/www/bbs-crm/storage/uploads"
UPLOAD_MAX_SIZE_MB="25"
UPLOAD_ALLOWED_MIME="application/pdf,image/jpeg,image/png,image/webp,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword"

# -----------------------------------------------------------------------------
# İlk kurulum — seed (production'da bir kez çalıştır, sonra kaldır)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@firmaismi.com"
SEED_ADMIN_PASSWORD="GucluSifre123!"
