# =============================================================================
# BBS CRM — Environment Variables (Hostinger VPS)
# Faz 0: Veritabanı katmanı
# Kopyalayın: cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL (Hostinger VPS — localhost veya private IP)
# -----------------------------------------------------------------------------
# Örnek: postgresql://bbs_user:STRONG_PASSWORD@127.0.0.1:5432/bbs_crm?schema=public
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bbs_crm?schema=public"

# Shadow DB — sadece `prisma migrate dev` için (geliştirme ortamı)
# Production'da migrate deploy kullanılır; shadow gerekmez
SHADOW_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bbs_crm_shadow?schema=public"

# -----------------------------------------------------------------------------
# NextAuth (Faz 1+ — şimdiden tanımlı)
# -----------------------------------------------------------------------------
NEXTAUTH_URL="http://localhost:3000"
# Zorunlu — gerçek rastgele değer (tırnak içinde, en az 32 karakter)
# Üretmek için: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET="degistirin-guclu-rastgele-secret-en-az-32-karakter"
AUTH_SECRET="degistirin-guclu-rastgele-secret-en-az-32-karakter"
AUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Local dosya depolama (Hostinger VPS)
# Mutlak yol önerilir; web root dışında tutun
# -----------------------------------------------------------------------------
STORAGE_DRIVER="local"
UPLOAD_DIR="/var/www/bbs-crm/storage/uploads"
UPLOAD_MAX_SIZE_MB="25"
UPLOAD_ALLOWED_MIME="application/pdf,image/jpeg,image/png,image/webp,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/msword"

# -----------------------------------------------------------------------------
# Uygulama (Faz 1+)
# -----------------------------------------------------------------------------
NODE_ENV="production"
APP_URL="https://crm.sirketiniz.com"
APP_TIMEZONE="Europe/Istanbul"
APP_LOCALE="tr-TR"

# -----------------------------------------------------------------------------
# Seed (geliştirme — production'da kullanmayın)
# -----------------------------------------------------------------------------
SEED_ADMIN_EMAIL="admin@sirketiniz.com"
SEED_ADMIN_PASSWORD="Degistirin-Guclu-Sifre-123!"

# -----------------------------------------------------------------------------
# E-posta (Faz 4 — bildirimler)
# -----------------------------------------------------------------------------
# SMTP_HOST="smtp.sirketiniz.com"
# SMTP_PORT="587"
# SMTP_USER=""
# SMTP_PASSWORD=""
# SMTP_FROM="noreply@sirketiniz.com"
